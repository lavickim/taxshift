# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=moneyshift
DB_USER=postgres
DB_PASSWORD=postgres

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
