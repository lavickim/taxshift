{
  "todoManagement": {
    "enabled": true,
    "masterTodoPath": "project-design/todo/master-todolist.md",
    "todoDirectory": "project-design/todo/",
    "autoUpdate": true,
    "reminderFrequency": "daily",
    "prioritySystem": {
      "high": "🔴",
      "medium": "🟡",
      "low": "🟢",
      "info": "⚪"
    },
    "statusIcons": {
      "pending": "[ ]",
      "completed": "[x]",
      "verified": "✅",
      "inProgress": "🔄",
      "paused": "⏸️",
      "cancelled": "❌"
    },
    "rules": [
      "Use TodoWrite tool proactively for complex multi-step tasks",
      "Update todo status immediately after completing tasks",
      "Break down large tasks into smaller, manageable items",
      "Always specify priority and estimated time for new tasks",
      "Review and update master todolist weekly"
    ]
  },
  "developmentWorkflow": {
    "enabled": true,
    "methodology": "TDD",
    "mandatoryPractices": {
      "testFirst": {
        "enabled": true,
        "description": "Always write failing tests before implementing functionality",
        "exceptions": [
          "emergency bug fixes",
          "trivial changes"
        ],
        "enforcementLevel": "strict"
      },
      "testCoverage": {
        "minimum": 80,
        "target": 95,
        "criticalPaths": 100
      },
      "codeQuality": {
        "linting": true,
        "typeChecking": true,
        "formatOnSave": true
      }
    },
    "testingStrategy": {
      "unitTests": {
        "framework": "Jest",
        "location": "src/**/__tests__/**/*.test.ts|tsx",
        "naming": "[ComponentName].test.ts|tsx",
        "mandatory": true
      },
      "integrationTests": {
        "framework": "Jest + Testing Library",
        "location": "src/**/__tests__/integration/**/*.test.ts|tsx",
        "mandatory": true
      },
      "e2eTests": {
        "framework": "Puppeteer",
        "location": "tests/e2e/**/*.test.ts",
        "mandatory": false
      }
    },
    "projectSpecific": {
      "mobile": {
        "testingLibrary": "@testing-library/react-native",
        "mockStrategy": "jest.setup.js",
        "testCommand": "yarn test"
      },
      "admin": {
        "testingLibrary": "@testing-library/react",
        "mockStrategy": "jest.config.js",
        "testCommand": "yarn test"
      },
      "backend": {
        "testingFramework": "JUnit 5",
        "mockStrategy": "Mockito",
        "testCommand": "mvn test"
      }
    },
    "automatedChecks": {
      "preCommit": [
        "test",
        "lint",
        "type-check"
      ],
      "prePush": [
        "test:coverage",
        "build"
      ],
      "ci": [
        "test:all",
        "build:all",
        "security-scan"
      ]
    },
    "tddWorkflow": [
      "Write failing test first",
      "Write minimal code to pass test",
      "Refactor while keeping tests green",
      "Add more test cases",
      "Repeat until feature complete"
    ]
  },
  "projectDesignDocuments": {
    "enabled": true,
    "referenceRequired": true,
    "discrepancyReporting": true,
    "documentsPath": "project-design/",
    "keyDocuments": [
      "project-design/기장시스템구현.md",
      "project-design/기장시스템구현계획서.md",
      "project-design/todo/master-todolist.md",
      "project-design/todo/mobile-bookkeeping-todolist.md"
    ],
    "rules": [
      "Always reference relevant design documents before implementation",
      "Report any discrepancies between implementation and design documents",
      "Update design documents if implementation requires changes",
      "Validate implementation against design requirements",
      "Maintain traceability between requirements and implementation"
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git checkout:*)"
    ],
    "deny": []
  }
}