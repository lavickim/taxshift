# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ===========================================
# Java / Maven / Spring Boot
# ===========================================
target/
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
*.class
.mvn/
mvnw
mvnw.cmd

# Spring Boot specific
application-*.properties
application-*.yml
application-*.yaml
!application.yml
!application.properties

# Log files
*.log
logs/
app.log*

# IDE files
.idea/
.vscode/
*.iws
*.iml
*.ipr
*.swp
*.swo
*~

# ===========================================
# Node.js / NextJS
# ===========================================
# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
mshift-admin/.next/

# production
/build
/dist

# ===========================================
# Environment & Config
# ===========================================
# env files (can opt-in for committing if needed)
.env
.env.*
.env*.local
!.env.example

# ===========================================
# Database & Cache
# ===========================================
# Database
*.db
*.sqlite
*.sqlite3

# Redis
dump.rdb

# ===========================================
# OS & Misc
# ===========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.pem

# Temporary files
*.tmp
*.temp
.cache/

# ===========================================
# Development & Debug
# ===========================================
# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Backup files
*.bak
*.backup
*.orig

# ===========================================
# Build tools
# ===========================================
# typescript
*.tsbuildinfo
next-env.d.ts

# Vercel
.vercel

# ===========================================
# Large data files (CSV, Excel, etc.)
# ===========================================
*.csv
*.xlsx
*.xls
data/source/*
!data/source/.gitkeep
*.dump
*.sql.gz

# ===========================================
# Generated files
# ===========================================
/lib/generated/prisma

# Test results
test-results/
junit.xml
