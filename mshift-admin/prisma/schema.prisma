generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                         String          @id @db.Uuid
  companyName                String          @map("company_name")
  businessRegistrationNumber String?         @unique @map("business_registration_number") @db.VarChar(20)
  createdAt                  DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  taxpayerType               TaxpayerType    @default(CORPORATION) @map("taxpayer_type")
  ruleCandidates             RuleCandidate[]
  rules                      Rule[]
  transactions               Transaction[]

  @@map("companies")
}

model TransactionCache {
  rawTextHash String   @id @map("raw_text_hash") @db.Char(64)
  rawText     String   @map("raw_text")
  uniqueKey   String   @map("unique_key")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("transaction_cache")
}

model Rule {
  id                  Int         @id @default(autoincrement())
  companyId           String      @map("company_id") @db.Uuid
  uniqueKey           String      @map("unique_key")
  targetDebitAccount  String      @map("target_debit_account") @db.VarChar(100)
  targetCreditAccount String      @default("보통예금") @map("target_credit_account") @db.VarChar(100)
  targetSuggestedTag  String?     @map("target_suggested_tag") @db.VarChar(100)
  vatApplicable       Boolean     @default(false) @map("vat_applicable")
  priority            Int         @default(0)
  isActive            Boolean     @default(true) @map("is_active")
  createdAt           DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy           RuleCreator @default(AUTO_GENERATED) @map("created_by")
  company             Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, uniqueKey])
  @@index([companyId, uniqueKey], map: "idx_rules_company_id_unique_key")
  @@map("rules")
}

model RuleCandidate {
  id                 Int      @id @default(autoincrement())
  companyId          String   @map("company_id") @db.Uuid
  uniqueKey          String   @map("unique_key")
  targetDebitAccount String   @map("target_debit_account") @db.VarChar(100)
  targetSuggestedTag String?  @map("target_suggested_tag") @db.VarChar(100)
  vatApplicable      Boolean? @map("vat_applicable")
  suggestionCount    Int      @default(1) @map("suggestion_count")
  lastSuggestedAt    DateTime @default(now()) @map("last_suggested_at") @db.Timestamptz(6)
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, uniqueKey, targetDebitAccount], map: "uq_company_key_account")
  @@map("rule_candidates")
}

model Transaction {
  id                      BigInt              @id @default(autoincrement())
  companyId               String              @map("company_id") @db.Uuid
  rawText                 String              @map("raw_text")
  transactionDate         DateTime            @map("transaction_date") @db.Date
  amount                  BigInt
  normalizedUniqueKey     String?             @map("normalized_unique_key")
  isAnomaly               Boolean             @default(false) @map("is_anomaly")
  anomalyScore            Decimal?            @map("anomaly_score") @db.Decimal(5, 4)
  llmResponse             Json?               @map("llm_response")
  userClarification       Json?               @map("user_clarification")
  finalDebitAccount       String?             @map("final_debit_account") @db.VarChar(100)
  finalCreditAccount      String?             @map("final_credit_account") @db.VarChar(100)
  finalSuggestedTag       String?             @map("final_suggested_tag") @db.VarChar(100)
  createdAt               DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  transactionType         TransactionIOType   @map("transaction_type")
  status                  TransactionStatus   @default(NORMALIZED)
  processedBy             ProcessorType?      @map("processed_by")
  confidenceScores        Json?               @map("confidence_scores")
  keywordExtractionResult Json?               @map("keyword_extraction_result")
  processingPath          String?             @map("processing_path") @db.VarChar(50)
  tagMatchingResult       Json?               @map("tag_matching_result")
  userAnswerOptionId      BigInt?             @map("user_answer_option_id")
  userQuestionId          BigInt?             @map("user_question_id")
  confidenceHistory       ConfidenceHistory[]
  company                 Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userAnswerOption        QuestionOption?     @relation(fields: [userAnswerOptionId], references: [id])
  userQuestion            UserQuestion?       @relation(fields: [userQuestionId], references: [id])

  @@index([companyId, status], map: "idx_transactions_company_id_status")
  @@index([transactionDate], map: "idx_transactions_transaction_date")
  @@index([userQuestionId], map: "idx_transactions_user_question")
  @@index([processingPath], map: "idx_transactions_processing_path")
  @@map("transactions")
}

model DatacollectionGyeonggiDelivery {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listTotalCount     Int?     @map("list_total_count")
  responseCode       String?  @map("response_code")
  responseMessage    String?  @map("response_message")
  apiVersion         String?  @map("api_version")
  businessRegNo      String   @unique @map("business_reg_no")
  sigunName          String?  @map("sigun_name")
  storeName          String   @map("store_name")
  industryType       String?  @map("industry_type")
  refinedRoadAddress String?  @map("refined_road_address")
  refinedLotAddress  String?  @map("refined_lot_address")
  refinedZipcode     String?  @map("refined_zipcode")
  refinedLatitude    Decimal? @map("refined_latitude") @db.Decimal(10, 8)
  refinedLongitude   Decimal? @map("refined_longitude") @db.Decimal(11, 8)
  dataSource         String   @default("gyeonggi_delivery") @map("data_source")
  collectionBatchId  String?  @map("collection_batch_id")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("datacollection_gyeonggi_delivery")
}

model DatacollectionSeoulRestaurants {
  id                         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  licenseDate                String?  @map("license_date")
  businessStatusCode         String?  @map("business_status_code")
  businessStatusName         String?  @map("business_status_name")
  businessName               String   @map("business_name")
  businessType               String?  @map("business_type")
  dataSource                 String   @default("seoul_restaurants") @map("data_source")
  collectionBatchId          String?  @map("collection_batch_id")
  createdAt                  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  apiVersion                 String?  @map("api_version")
  businessRegistrationNumber String?  @unique @map("business_registration_number")
  licenseExpiryDate          String?  @map("license_expiry_date")
  listTotalCount             Int?     @map("list_total_count")
  lotNumberAddress           String?  @map("lot_number_address")
  refinedLatitude            Decimal? @map("refined_latitude") @db.Decimal(10, 8)
  refinedLongitude           Decimal? @map("refined_longitude") @db.Decimal(11, 8)
  responseCode               String?  @map("response_code")
  responseMessage            String?  @map("response_message")
  roadNameAddress            String?  @map("road_name_address")
  zipCode                    String?  @map("zip_code")

  @@map("datacollection_seoul_restaurants")
}

model FranchiseBrands {
  id                          Int       @id @default(autoincrement())
  businessYear                String    @map("business_year")
  brandId                     String    @unique @map("brand_id")
  headquartersId              String?   @map("headquarters_id")
  businessRegistrationNumber  String?   @map("business_registration_number")
  corporateRegistrationNumber String?   @map("corporate_registration_number")
  representativeName          String?   @map("representative_name")
  brandName                   String    @map("brand_name")
  industryLargeCategory       String?   @map("industry_large_category")
  industryMediumCategory      String?   @map("industry_medium_category")
  mainProduct                 String?   @map("main_product")
  businessStartDate           DateTime? @map("business_start_date") @db.Date
  companyName                 String?   @map("company_name")
  createdAt                   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  generatedTransactionString  String?   @map("generated_transaction_string")
  lastTestAt                  DateTime? @map("last_test_at") @db.Timestamptz(6)
  primaryTag                  String?   @map("primary_tag") @db.VarChar(100)
  secondaryTag                String?   @map("secondary_tag") @db.VarChar(100)
  tagGenerationReason         String?   @map("tag_generation_reason")
  tertiaryTag                 String?   @map("tertiary_tag") @db.VarChar(100)
  testPassed                  Boolean?  @map("test_passed")
  testResult                  Json?     @map("test_result")

  @@unique([brandId, businessYear], map: "unique_brand_year")
  @@index([brandName], map: "idx_franchise_brand_name")
  @@index([businessYear], map: "idx_franchise_business_year")
  @@index([companyName], map: "idx_franchise_company_name")
  @@index([industryLargeCategory, industryMediumCategory], map: "idx_franchise_industry")
  @@index([testPassed], map: "idx_franchise_test_passed")
  @@index([lastTestAt], map: "idx_franchise_last_test_at")
  @@index([primaryTag], map: "idx_franchise_primary_tag")
  @@map("franchise_brands")
}

model NationalPensionWorkplaces {
  id                         Int      @id @default(autoincrement())
  dataYearMonth              String   @map("data_year_month")
  workplaceName              String   @map("workplace_name")
  businessRegistrationNumber String   @map("business_registration_number")
  workplaceStatusCode        Int      @map("workplace_status_code")
  postalCode                 String?  @map("postal_code")
  addressJibun               String?  @map("address_jibun")
  addressRoad                String?  @map("address_road")
  legalDongCode              String?  @map("legal_dong_code")
  adminDongCode              String?  @map("admin_dong_code")
  sidoCode                   String?  @map("sido_code")
  sigunguCode                String?  @map("sigungu_code")
  eubmyeondongCode           String?  @map("eubmyeondong_code")
  workplaceTypeCode          Int?     @map("workplace_type_code")
  industryCode               String?  @map("industry_code")
  industryName               String?  @map("industry_name")
  applicationDate            String?  @map("application_date")
  reRegistrationDate         String?  @map("re_registration_date")
  withdrawalDate             String?  @map("withdrawal_date")
  memberCount                Int?     @map("member_count")
  monthlyNoticeAmount        BigInt?  @map("monthly_notice_amount")
  newAcquisitionCount        Int?     @map("new_acquisition_count")
  lossCount                  Int?     @map("loss_count")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([dataYearMonth], map: "idx_national_pension_data_year_month")
  @@index([workplaceStatusCode], map: "idx_national_pension_status")
  @@index([industryCode], map: "idx_national_pension_industry")
  @@index([addressRoad], map: "idx_national_pension_address")
  @@map("national_pension_workplaces")
}

model regex_rules {
  id                      BigInt    @id @default(autoincrement())
  pattern                 String    @db.VarChar(1000)
  replacement             String?   @db.VarChar(1000)
  description             String?
  category                String?   @db.VarChar(100)
  enabled                 Boolean?  @default(true)
  priority                Int?      @default(0)
  created_at              DateTime? @default(now()) @db.Timestamp(6)
  updated_at              DateTime? @default(now()) @db.Timestamp(6)
  confidence              Decimal?  @default(0.0) @db.Decimal(3, 2)
  normalizer_type         String?   @db.VarChar(100)
  created_by              String?   @default("ADMIN") @db.VarChar(50)
  is_active               Boolean?  @default(true)
  keyword                 String?   @db.VarChar(255)
  last_used               DateTime? @db.Timestamptz(6)
  negative_count          Int?      @default(0)
  pattern_type            String?   @default("BRAND") @db.VarChar(20)
  positive_count          Int?      @default(0)
  primary_account         String?   @db.VarChar(100)
  primary_tag             String?   @db.VarChar(100)
  secondary_account       String?   @db.VarChar(100)
  secondary_tag           String?   @db.VarChar(100)
  success_rate            Decimal?  @db.Decimal(5, 2)
  tags                    String?   @db.VarChar(500)
  usage_count             Int?      @default(0)
  context_rules           Json?     @map("context_rules")
  display_order           Int?      @default(100) @map("display_order")
  parent_keyword_group_id BigInt?   @map("parent_keyword_group_id")

  @@index([category], map: "idx_regex_rules_category")
  @@index([enabled], map: "idx_regex_rules_enabled")
  @@index([enabled, category], map: "idx_regex_rules_enabled_category")
  @@index([normalizer_type], map: "idx_regex_rules_normalizer_type")
  @@index([priority], map: "idx_regex_rules_priority")
  @@index([pattern_type], map: "idx_regex_rules_pattern_type")
  @@index([keyword], map: "idx_regex_rules_keyword")
  @@index([is_active], map: "idx_regex_rules_is_active")
  @@index([parent_keyword_group_id], map: "idx_regex_rules_parent_keyword_group")
  @@index([display_order], map: "idx_regex_rules_display_order")
}

model KeywordGroup {
  id                 BigInt              @id @default(autoincrement())
  groupName          String              @map("group_name") @db.VarChar(100)
  primaryKeyword     String              @map("primary_keyword") @db.VarChar(100)
  synonyms           String[]            @db.VarChar(50)
  category           String?             @db.VarChar(50)
  confidenceBase     Decimal             @default(0.70) @map("confidence_base") @db.Decimal(3, 2)
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  keywordTagMappings KeywordTagMapping[]

  @@index([category], map: "idx_keyword_groups_category")
  @@index([isActive], map: "idx_keyword_groups_active")
  @@index([primaryKeyword], map: "idx_keyword_groups_primary_keyword")
  @@map("keyword_groups")
}

model TagsMaster {
  id                 BigInt              @id @default(autoincrement())
  tagName            String              @unique @map("tag_name") @db.VarChar(100)
  tagCategory        String?             @map("tag_category") @db.VarChar(50)
  description        String?
  colorHex           String              @default("#6B7280") @map("color_hex") @db.VarChar(7)
  iconName           String              @default("tag") @map("icon_name") @db.VarChar(50)
  displayOrder       Int                 @default(100) @map("display_order")
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  keywordTagMappings KeywordTagMapping[]
  tagAccountMappings TagAccountMapping[]
  userQuestions      UserQuestion[]

  @@index([tagCategory], map: "idx_tags_master_category")
  @@index([isActive], map: "idx_tags_master_active")
  @@index([displayOrder], map: "idx_tags_master_display_order")
  @@map("tags_master")
}

model KeywordTagMapping {
  id              BigInt       @id @default(autoincrement())
  keywordGroupId  BigInt       @map("keyword_group_id")
  tagId           BigInt       @map("tag_id")
  confidenceScore Decimal      @default(0.70) @map("confidence_score") @db.Decimal(3, 2)
  contextRules    Json?        @map("context_rules")
  priority        Int          @default(50)
  usageCount      BigInt       @default(0) @map("usage_count")
  isActive        Boolean      @default(true) @map("is_active")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  keywordGroup    KeywordGroup @relation(fields: [keywordGroupId], references: [id], onDelete: Cascade)
  tag             TagsMaster   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([keywordGroupId, tagId], map: "uq_keyword_tag_mapping")
  @@index([keywordGroupId], map: "idx_keyword_tag_mappings_keyword_group")
  @@index([tagId], map: "idx_keyword_tag_mappings_tag")
  @@index([isActive], map: "idx_keyword_tag_mappings_active")
  @@index([confidenceScore], map: "idx_keyword_tag_mappings_confidence")
  @@map("keyword_tag_mappings")
}

model TagAccountMapping {
  id               BigInt     @id @default(autoincrement())
  tagId            BigInt     @map("tag_id")
  accountCode      String     @map("account_code") @db.VarChar(20)
  accountName      String     @map("account_name") @db.VarChar(100)
  mappingCondition Json?      @map("mapping_condition")
  isDefault        Boolean    @default(false) @map("is_default")
  priority         Int        @default(50)
  confidenceBoost  Decimal    @default(0.0) @map("confidence_boost") @db.Decimal(3, 2)
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  tag              TagsMaster @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@index([tagId], map: "idx_tag_account_mappings_tag")
  @@index([accountCode], map: "idx_tag_account_mappings_account_code")
  @@index([isDefault], map: "idx_tag_account_mappings_default")
  @@map("tag_account_mappings")
}

model UserQuestion {
  id                  BigInt           @id @default(autoincrement())
  triggerTagId        BigInt?          @map("trigger_tag_id")
  triggerConditions   Json             @map("trigger_conditions")
  questionText        String           @map("question_text")
  questionType        String           @default("SINGLE_CHOICE") @map("question_type") @db.VarChar(20)
  confidenceThreshold Decimal          @default(0.85) @map("confidence_threshold") @db.Decimal(3, 2)
  isActive            Boolean          @default(true) @map("is_active")
  usageCount          BigInt           @default(0) @map("usage_count")
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  questionOptions     QuestionOption[]
  transactions        Transaction[]
  tag                 TagsMaster?      @relation(fields: [triggerTagId], references: [id])

  @@index([triggerTagId], map: "idx_user_questions_trigger_tag")
  @@index([isActive], map: "idx_user_questions_active")
  @@index([questionType], map: "idx_user_questions_type")
  @@map("user_questions")
}

model QuestionOption {
  id             BigInt        @id @default(autoincrement())
  questionId     BigInt        @map("question_id")
  optionText     String        @map("option_text") @db.VarChar(200)
  optionValue    Json          @map("option_value")
  selectionCount BigInt        @default(0) @map("selection_count")
  displayOrder   Int           @default(100) @map("display_order")
  isActive       Boolean       @default(true) @map("is_active")
  question       UserQuestion  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  transactions   Transaction[]

  @@index([questionId], map: "idx_question_options_question")
  @@index([displayOrder], map: "idx_question_options_display_order")
  @@map("question_options")
}

model ConfidenceHistory {
  id               BigInt       @id @default(autoincrement())
  entityType       String       @map("entity_type") @db.VarChar(50)
  entityId         BigInt       @map("entity_id")
  oldConfidence    Decimal?     @map("old_confidence") @db.Decimal(3, 2)
  newConfidence    Decimal      @map("new_confidence") @db.Decimal(3, 2)
  adjustmentReason String?      @map("adjustment_reason") @db.VarChar(100)
  adjustedBy       String?      @map("adjusted_by") @db.VarChar(50)
  transactionId    BigInt?      @map("transaction_id")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  transaction      Transaction? @relation(fields: [transactionId], references: [id])

  @@index([entityType, entityId], map: "idx_confidence_history_entity")
  @@index([createdAt], map: "idx_confidence_history_created")
  @@map("confidence_history")
}

model LlmRuleCandidate {
  id                 BigInt    @id @default(autoincrement())
  transactionSamples String[]  @map("transaction_samples")
  suggestedPattern   String?   @map("suggested_pattern") @db.VarChar(500)
  suggestedKeywords  String[]  @map("suggested_keywords")
  suggestedTag       String?   @map("suggested_tag") @db.VarChar(100)
  suggestedAccount   String?   @map("suggested_account") @db.VarChar(100)
  occurrenceCount    Int       @default(1) @map("occurrence_count")
  confidenceEstimate Decimal?  @map("confidence_estimate") @db.Decimal(3, 2)
  status             String    @default("PENDING") @map("status") @db.VarChar(20)
  reviewedBy         String?   @map("reviewed_by") @db.VarChar(50)
  reviewedAt         DateTime? @map("reviewed_at") @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([status], map: "idx_llm_rule_candidates_status")
  @@index([occurrenceCount], map: "idx_llm_rule_candidates_occurrence")
  @@index([createdAt], map: "idx_llm_rule_candidates_created")
  @@map("llm_rule_candidates")
}

model TestTransactionString {
  id                  BigInt    @id @default(autoincrement())
  transactionText     String    @map("transaction_text")
  amount              Int?      @map("amount")
  formattedAmount     String?   @map("formatted_amount") @db.VarChar(50)
  category            String?   @map("category") @db.VarChar(100)
  expectedTag         String?   @map("expected_tag") @db.VarChar(100)
  expectedAccountCode String?   @map("expected_account_code") @db.VarChar(20)
  expectedAccountName String?   @map("expected_account_name") @db.VarChar(100)
  description         String?   @map("description")
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  lastTestResult      Json?     @map("last_test_result")
  lastTestAt          DateTime? @map("last_test_at") @db.Timestamptz(6)
  isMatched           Boolean?  @map("is_matched")

  @@index([category], map: "idx_test_transactions_category")
  @@index([isActive], map: "idx_test_transactions_active")
  @@index([isMatched], map: "idx_test_transactions_matched")
  @@index([lastTestAt], map: "idx_test_transactions_last_test")
  @@map("test_transaction_strings")
}

enum TaxpayerType {
  CORPORATION
  SOLE_PROPRIETORSHIP

  @@map("taxpayer_type_enum")
}

enum RuleCreator {
  ADMIN
  AUTO_GENERATED

  @@map("rule_creator_enum")
}

enum TransactionStatus {
  NORMALIZED
  RULE_PROCESSED
  NEEDS_CLARIFICATION
  LLM_PROCESSED
  CLARIFIED
  NEEDS_REVIEW

  @@map("transaction_status_enum")
}

enum ProcessorType {
  CACHE
  REGEX_FILTER
  INFERENCE_ML
  NORMALIZER_LLM
  RULE_ENGINE
  ANALYZER_LLM

  @@map("processor_type_enum")
}

enum TransactionIOType {
  EXPENSE
  INCOME

  @@map("transaction_io_type")
}
