generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                         String          @id @db.Uuid
  companyName                String          @map("company_name")
  businessRegistrationNumber String?         @unique @map("business_registration_number") @db.VarChar(20)
  createdAt                  DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  taxpayerType               TaxpayerType    @default(CORPORATION) @map("taxpayer_type")
  ruleCandidates             RuleCandidate[]
  rules                      Rule[]
  transactions               Transaction[]

  @@map("companies")
}

model TransactionCache {
  rawTextHash String   @id @map("raw_text_hash") @db.Char(64)
  rawText     String   @map("raw_text")
  uniqueKey   String   @map("unique_key")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("transaction_cache")
}

model Rule {
  id                  Int         @id @default(autoincrement())
  companyId           String      @map("company_id") @db.Uuid
  uniqueKey           String      @map("unique_key")
  targetDebitAccount  String      @map("target_debit_account") @db.VarChar(100)
  targetCreditAccount String      @default("보통예금") @map("target_credit_account") @db.VarChar(100)
  targetSuggestedTag  String?     @map("target_suggested_tag") @db.VarChar(100)
  vatApplicable       Boolean     @default(false) @map("vat_applicable")
  priority            Int         @default(0)
  isActive            Boolean     @default(true) @map("is_active")
  createdAt           DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy           RuleCreator @default(AUTO_GENERATED) @map("created_by")
  company             Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, uniqueKey])
  @@index([companyId, uniqueKey], map: "idx_rules_company_id_unique_key")
  @@map("rules")
}

model RuleCandidate {
  id                 Int      @id @default(autoincrement())
  companyId          String   @map("company_id") @db.Uuid
  uniqueKey          String   @map("unique_key")
  targetDebitAccount String   @map("target_debit_account") @db.VarChar(100)
  targetSuggestedTag String?  @map("target_suggested_tag") @db.VarChar(100)
  vatApplicable      Boolean? @map("vat_applicable")
  suggestionCount    Int      @default(1) @map("suggestion_count")
  lastSuggestedAt    DateTime @default(now()) @map("last_suggested_at") @db.Timestamptz(6)
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, uniqueKey, targetDebitAccount], map: "uq_company_key_account")
  @@map("rule_candidates")
}

model Transaction {
  id                  BigInt            @id @default(autoincrement())
  companyId           String            @map("company_id") @db.Uuid
  rawText             String            @map("raw_text")
  transactionDate     DateTime          @map("transaction_date") @db.Date
  amount              BigInt
  normalizedUniqueKey String?           @map("normalized_unique_key")
  isAnomaly           Boolean           @default(false) @map("is_anomaly")
  anomalyScore        Decimal?          @map("anomaly_score") @db.Decimal(5, 4)
  llmResponse         Json?             @map("llm_response")
  userClarification   Json?             @map("user_clarification")
  finalDebitAccount   String?           @map("final_debit_account") @db.VarChar(100)
  finalCreditAccount  String?           @map("final_credit_account") @db.VarChar(100)
  finalSuggestedTag   String?           @map("final_suggested_tag") @db.VarChar(100)
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  transactionType     TransactionIOType @map("transaction_type")
  status              TransactionStatus @default(NORMALIZED)
  processedBy         ProcessorType?    @map("processed_by")
  company             Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status], map: "idx_transactions_company_id_status")
  @@index([transactionDate], map: "idx_transactions_transaction_date")
  @@map("transactions")
}

model DatacollectionGyeonggiDelivery {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listTotalCount     Int?     @map("list_total_count")
  responseCode       String?  @map("response_code")
  responseMessage    String?  @map("response_message")
  apiVersion         String?  @map("api_version")
  businessRegNo      String   @unique @map("business_reg_no")
  sigunName          String?  @map("sigun_name")
  storeName          String   @map("store_name")
  industryType       String?  @map("industry_type")
  refinedRoadAddress String?  @map("refined_road_address")
  refinedLotAddress  String?  @map("refined_lot_address")
  refinedZipcode     String?  @map("refined_zipcode")
  refinedLatitude    Decimal? @map("refined_latitude") @db.Decimal(10, 8)
  refinedLongitude   Decimal? @map("refined_longitude") @db.Decimal(11, 8)
  dataSource         String   @default("gyeonggi_delivery") @map("data_source")
  collectionBatchId  String?  @map("collection_batch_id")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("datacollection_gyeonggi_delivery")
}

model DatacollectionSeoulRestaurants {
  id                         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  licenseDate                String?  @map("license_date")
  businessStatusCode         String?  @map("business_status_code")
  businessStatusName         String?  @map("business_status_name")
  businessName               String   @map("business_name")
  businessType               String?  @map("business_type")
  dataSource                 String   @default("seoul_restaurants") @map("data_source")
  collectionBatchId          String?  @map("collection_batch_id")
  createdAt                  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  apiVersion                 String?  @map("api_version")
  businessRegistrationNumber String?  @unique @map("business_registration_number")
  licenseExpiryDate          String?  @map("license_expiry_date")
  listTotalCount             Int?     @map("list_total_count")
  lotNumberAddress           String?  @map("lot_number_address")
  refinedLatitude            Decimal? @map("refined_latitude") @db.Decimal(10, 8)
  refinedLongitude           Decimal? @map("refined_longitude") @db.Decimal(11, 8)
  responseCode               String?  @map("response_code")
  responseMessage            String?  @map("response_message")
  roadNameAddress            String?  @map("road_name_address")
  zipCode                    String?  @map("zip_code")

  @@map("datacollection_seoul_restaurants")
}

model RuleEngine {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  keyword          String    @unique
  confidence       Int       @default(70)
  question         String?
  primaryTag       String    @map("primary_tag")
  primaryAccount   String    @map("primary_account")
  secondaryTag     String?   @map("secondary_tag")
  secondaryAccount String?   @map("secondary_account")
  usageCount       Int       @default(0) @map("usage_count")
  positiveCount    Int       @default(0) @map("positive_count")
  negativeCount    Int       @default(0) @map("negative_count")
  lastUsed         DateTime? @map("last_used") @db.Timestamptz(6)
  isActive         Boolean   @default(true) @map("is_active")
  createdBy        String    @default("ADMIN") @map("created_by")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([keyword], map: "idx_rule_engine_keyword")
  @@index([confidence], map: "idx_rule_engine_confidence")
  @@map("rule_engine")
}

model RuleEngineCandidate {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  keyword           String
  tag               String
  account           String
  suggestionCount   Int       @default(1) @map("suggestion_count")
  approvalThreshold Int       @default(10) @map("approval_threshold")
  firstSuggested    DateTime  @default(now()) @map("first_suggested") @db.Timestamptz(6)
  lastSuggested     DateTime  @default(now()) @map("last_suggested") @db.Timestamptz(6)
  isApproved        Boolean   @default(false) @map("is_approved")
  approvedAt        DateTime? @map("approved_at") @db.Timestamptz(6)
  approvedBy        String?   @map("approved_by")

  @@unique([keyword, tag, account], map: "uq_rule_engine_candidate")
  @@index([suggestionCount], map: "idx_rule_engine_candidate_count")
  @@map("rule_engine_candidates")
}

model RuleEngineFeedback {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ruleId          String?  @map("rule_id") @db.Uuid
  transactionText String   @map("transaction_text")
  normalizedText  String   @map("normalized_text")
  selectedOption  Int      @map("selected_option")
  selectedTag     String   @map("selected_tag")
  selectedAccount String   @map("selected_account")
  feedbackType    String   @map("feedback_type")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([ruleId], map: "idx_rule_engine_feedback_rule")
  @@map("rule_engine_feedback")
}

model FranchiseBrands {
  id                          Int       @id @default(autoincrement())
  businessYear                String    @map("business_year")
  brandId                     String    @unique @map("brand_id")
  headquartersId              String?   @map("headquarters_id")
  businessRegistrationNumber  String?   @map("business_registration_number")
  corporateRegistrationNumber String?   @map("corporate_registration_number")
  representativeName          String?   @map("representative_name")
  brandName                   String    @map("brand_name")
  industryLargeCategory       String?   @map("industry_large_category")
  industryMediumCategory      String?   @map("industry_medium_category")
  mainProduct                 String?   @map("main_product")
  businessStartDate           DateTime? @map("business_start_date") @db.Date
  companyName                 String?   @map("company_name")
  createdAt                   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@unique([brandId, businessYear], map: "unique_brand_year")
  @@index([brandName], map: "idx_franchise_brand_name")
  @@index([businessYear], map: "idx_franchise_business_year")
  @@index([companyName], map: "idx_franchise_company_name")
  @@index([industryLargeCategory, industryMediumCategory], map: "idx_franchise_industry")
  @@map("franchise_brands")
}

model NationalPensionWorkplaces {
  id                         Int      @id @default(autoincrement())
  dataYearMonth              String   @map("data_year_month")
  workplaceName              String   @map("workplace_name")
  businessRegistrationNumber String   @map("business_registration_number")
  workplaceStatusCode        Int      @map("workplace_status_code")
  postalCode                 String?  @map("postal_code")
  addressJibun               String?  @map("address_jibun")
  addressRoad                String?  @map("address_road")
  legalDongCode              String?  @map("legal_dong_code")
  adminDongCode              String?  @map("admin_dong_code")
  sidoCode                   String?  @map("sido_code")
  sigunguCode                String?  @map("sigungu_code")
  eubmyeondongCode           String?  @map("eubmyeondong_code")
  workplaceTypeCode          Int?     @map("workplace_type_code")
  industryCode               String?  @map("industry_code")
  industryName               String?  @map("industry_name")
  applicationDate            String?  @map("application_date")
  reRegistrationDate         String?  @map("re_registration_date")
  withdrawalDate             String?  @map("withdrawal_date")
  memberCount                Int?     @map("member_count")
  monthlyNoticeAmount        BigInt?  @map("monthly_notice_amount")
  newAcquisitionCount        Int?     @map("new_acquisition_count")
  lossCount                  Int?     @map("loss_count")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([dataYearMonth], map: "idx_national_pension_data_year_month")
  @@index([workplaceStatusCode], map: "idx_national_pension_status")
  @@index([industryCode], map: "idx_national_pension_industry")
  @@index([addressRoad], map: "idx_national_pension_address")
  @@map("national_pension_workplaces")
}

model regex_rules {
  id              BigInt    @id @default(autoincrement())
  pattern         String    @db.VarChar(1000)
  replacement     String?   @db.VarChar(1000)
  description     String?
  category        String?   @db.VarChar(100)
  enabled         Boolean?  @default(true)
  priority        Int?      @default(0)
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  updated_at      DateTime? @default(now()) @db.Timestamp(6)
  confidence      Decimal?  @default(0.0) @db.Decimal(3, 2)
  normalizer_type String?   @db.VarChar(100)

  @@index([category], map: "idx_regex_rules_category")
  @@index([enabled], map: "idx_regex_rules_enabled")
  @@index([enabled, category], map: "idx_regex_rules_enabled_category")
  @@index([normalizer_type], map: "idx_regex_rules_normalizer_type")
  @@index([priority], map: "idx_regex_rules_priority")
}

enum TaxpayerType {
  CORPORATION
  SOLE_PROPRIETORSHIP

  @@map("taxpayer_type_enum")
}

enum RuleCreator {
  ADMIN
  AUTO_GENERATED

  @@map("rule_creator_enum")
}

enum TransactionStatus {
  NORMALIZED
  RULE_PROCESSED
  NEEDS_CLARIFICATION
  LLM_PROCESSED
  CLARIFIED
  NEEDS_REVIEW

  @@map("transaction_status_enum")
}

enum ProcessorType {
  CACHE
  REGEX_FILTER
  INFERENCE_ML
  NORMALIZER_LLM
  RULE_ENGINE
  ANALYZER_LLM

  @@map("processor_type_enum")
}

enum TransactionIOType {
  EXPENSE
  INCOME

  @@map("transaction_io_type")
}
