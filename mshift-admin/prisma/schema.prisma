generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyName                String           @map("company_name") @db.VarChar(255)
  businessRegistrationNumber String?          @unique @map("business_registration_number") @db.VarChar(20)
  createdAt                  DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime?        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  taxpayerType               TaxpayerType?    @default(CORPORATION) @map("taxpayer_type")
  generalLedgers             GeneralLedger[]
  newJournalEntries          JournalEntries[]
  transactions               Transaction[]

  @@map("companies")
}

model Transaction {
  id                 BigInt            @id @default(autoincrement())
  companyId          String            @map("company_id") @db.Uuid
  rawText            String            @map("raw_text")
  transactionDate    DateTime          @map("transaction_date") @db.Date
  amount             BigInt
  transactionType    TransactionIOType @map("transaction_type")
  finalDebitAccount  String?           @map("final_debit_account") @db.VarChar(100)
  finalCreditAccount String?           @map("final_credit_account") @db.VarChar(100)
  finalSuggestedTag  String?           @map("final_suggested_tag") @db.VarChar(100)
  createdAt          DateTime?         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime?         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  company            Company           @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([companyId], map: "idx_transactions_company_id")
  @@map("transactions")
}

model TagsMaster {
  id                 BigInt              @id @default(autoincrement())
  tagName            String              @unique @map("tag_name") @db.VarChar(100)
  tagCategory        String?             @map("tag_category") @db.VarChar(50)
  description        String?
  colorHex           String?             @default("#6B7280") @map("color_hex") @db.VarChar(7)
  iconName           String?             @default("tag") @map("icon_name") @db.VarChar(50)
  displayOrder       Int?                @default(100) @map("display_order")
  isActive           Boolean?            @default(true) @map("is_active")
  createdAt          DateTime?           @default(now()) @map("created_at") @db.Timestamptz(6)
  tagAccountMappings TagAccountMapping[]

  @@map("tags_master")
}

model TagAccountMapping {
  id                BigInt          @id @default(autoincrement())
  tagId             BigInt          @map("tag_id")
  accountCode       String          @map("account_code") @db.VarChar(20)
  accountName       String          @map("account_name") @db.VarChar(100)
  mappingCondition  Json?           @map("mapping_condition")
  isDefault         Boolean?        @default(false) @map("is_default")
  priority          Int?            @default(50)
  confidenceBoost   Decimal?        @default(0.0) @map("confidence_boost") @db.Decimal(3, 2)
  createdAt         DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  chart_of_accounts ChartOfAccounts @relation(fields: [accountCode], references: [accountCode], onDelete: NoAction, onUpdate: NoAction)
  tag               TagsMaster      @relation(fields: [tagId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("tag_account_mappings")
}

model ChartOfAccounts {
  id                   Int                  @id @default(autoincrement())
  accountCode          String               @unique @map("account_code") @db.VarChar(10)
  accountName          String               @map("account_name") @db.VarChar(100)
  accountType          AccountType          @map("account_type")
  accountSubtype       String?              @map("account_subtype") @db.VarChar(50)
  isDebitNormal        Boolean              @map("is_debit_normal")
  parentAccountId      Int?                 @map("parent_account_id")
  isActive             Boolean?             @default(true) @map("is_active")
  displayOrder         Int?                 @default(0) @map("display_order")
  createdAt            DateTime?            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime?            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  parentAccount        ChartOfAccounts?     @relation("AccountHierarchy", fields: [parentAccountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  childAccounts        ChartOfAccounts[]    @relation("AccountHierarchy")
  generalLedgers       GeneralLedger[]
  journalEntryDetails  JournalEntryDetail[]
  tag_account_mappings TagAccountMapping[]

  @@map("chart_of_accounts")
}

model GeneralLedger {
  id                     BigInt          @id @default(autoincrement())
  companyId              String          @map("company_id") @db.Uuid
  accountCode            String          @map("account_code") @db.VarChar(20)
  fiscalYear             Int             @map("fiscal_year")
  fiscalMonth            Int             @map("fiscal_month")
  beginningDebitBalance  Decimal?        @default(0) @map("beginning_debit_balance") @db.Decimal(18, 2)
  beginningCreditBalance Decimal?        @default(0) @map("beginning_credit_balance") @db.Decimal(18, 2)
  periodDebitAmount      Decimal?        @default(0) @map("period_debit_amount") @db.Decimal(18, 2)
  periodCreditAmount     Decimal?        @default(0) @map("period_credit_amount") @db.Decimal(18, 2)
  yearToDateDebit        Decimal?        @default(0) @map("year_to_date_debit") @db.Decimal(18, 2)
  yearToDateCredit       Decimal?        @default(0) @map("year_to_date_credit") @db.Decimal(18, 2)
  endingDebitBalance     Decimal?        @default(0) @map("ending_debit_balance") @db.Decimal(18, 2)
  endingCreditBalance    Decimal?        @default(0) @map("ending_credit_balance") @db.Decimal(18, 2)
  isClosed               Boolean?        @default(false) @map("is_closed")
  closedAt               DateTime?       @map("closed_at") @db.Timestamptz(6)
  createdAt              DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime?       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  chartOfAccount         ChartOfAccounts @relation(fields: [accountCode], references: [accountCode], onDelete: NoAction, onUpdate: NoAction)
  company                Company         @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  glDetails              GlDetail[]

  @@unique([companyId, accountCode, fiscalYear, fiscalMonth])
  @@index([companyId, fiscalYear], map: "idx_gl_company_year")
  @@map("general_ledger")
}

model GlDetail {
  id              BigInt         @id @default(autoincrement())
  generalLedgerId BigInt         @map("general_ledger_id")
  journalEntryId  BigInt         @map("journal_entry_id")
  postingDate     DateTime       @map("posting_date") @db.Date
  debitAmount     Decimal?       @default(0) @map("debit_amount") @db.Decimal(18, 2)
  creditAmount    Decimal?       @default(0) @map("credit_amount") @db.Decimal(18, 2)
  runningBalance  Decimal        @map("running_balance") @db.Decimal(18, 2)
  description     String?
  createdAt       DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  generalLedger   GeneralLedger  @relation(fields: [generalLedgerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  journalEntry    JournalEntries @relation(fields: [journalEntryId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("gl_details")
}

model JournalEntries {
  id                BigInt                      @id @default(autoincrement())
  companyId         String                      @map("company_id") @db.Uuid
  entryDate         DateTime                    @map("entry_date") @db.Date
  description       String
  totalDebitAmount  Decimal                     @map("total_debit_amount") @db.Decimal(18, 2)
  totalCreditAmount Decimal                     @map("total_credit_amount") @db.Decimal(18, 2)
  confidenceScore   Decimal?                    @map("confidence_score") @db.Decimal(5, 2)
  postedAt          DateTime?                   @map("posted_at") @db.Timestamptz(6)
  createdAt         DateTime?                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime?                   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  status            JournalEntryApprovalStatus? @default(DRAFT)
  glDetails         GlDetail[]
  company           Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  details           JournalEntryDetail[]

  @@index([companyId, entryDate], map: "idx_journal_entries_company_date")
  @@index([status], map: "idx_journal_entries_status")
  @@map("journal_entries")
}

model JournalEntryDetail {
  id             BigInt          @id @default(autoincrement())
  journalEntryId BigInt          @map("journal_entry_id")
  lineNumber     Int             @map("line_number")
  accountCode    String          @map("account_code") @db.VarChar(20)
  accountName    String          @map("account_name") @db.VarChar(100)
  debitAmount    Decimal?        @default(0) @map("debit_amount") @db.Decimal(18, 2)
  creditAmount   Decimal?        @default(0) @map("credit_amount") @db.Decimal(18, 2)
  description    String?
  costCenter     String?         @map("cost_center") @db.VarChar(50)
  projectCode    String?         @map("project_code") @db.VarChar(50)
  createdAt      DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  chartOfAccount ChartOfAccounts @relation(fields: [accountCode], references: [accountCode], onDelete: NoAction, onUpdate: NoAction)
  journalEntry   JournalEntries  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([journalEntryId], map: "idx_journal_entry_details_entry_id")
  @@map("journal_entry_details")
}

model RegexPreprocessingRule {
  id             BigInt                     @id @default(autoincrement())
  ruleName       String                     @map("rule_name") @db.VarChar(100)
  description    String?
  category       String                     @db.VarChar(50)
  inputPattern   String                     @map("input_pattern")
  outputTemplate String                     @map("output_template")
  priority       Int?                       @default(100)
  isActive       Boolean?                   @default(true) @map("is_active")
  metadataTags   Json?                      @map("metadata_tags")
  testCases      Json?                      @map("test_cases")
  usageCount     BigInt?                    @default(0) @map("usage_count")
  successRate    Decimal?                   @map("success_rate") @db.Decimal(5, 2)
  createdAt      DateTime?                  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime?                  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  test_examples  String[]
  category_ref   RegexPreprocessingCategory @relation(fields: [category], references: [categoryName], onDelete: NoAction, onUpdate: NoAction)

  @@index([isActive], map: "idx_regex_preprocessing_rules_active")
  @@index([isActive, priority(sort: Desc)], map: "idx_regex_preprocessing_rules_active_priority")
  @@index([category], map: "idx_regex_preprocessing_rules_category")
  @@index([priority], map: "idx_regex_preprocessing_rules_priority")
  @@map("regex_preprocessing_rules")
}

model RegexPreprocessingCategory {
  id           BigInt                   @id @default(autoincrement())
  categoryName String                   @unique @map("category_name") @db.VarChar(50)
  description  String?
  color_code   String?                  @default("#6B7280") @db.VarChar(7)
  isActive     Boolean?                 @default(true) @map("is_active")
  createdAt    DateTime?                @default(now()) @map("created_at") @db.Timestamp(6)
  rules        RegexPreprocessingRule[]

  @@map("regex_preprocessing_categories")
}

model RegexPreprocessingLog {
  id                BigInt   @id @default(autoincrement())
  originalText      String   @map("original_text")
  normalizedText    String?  @map("normalized_text")
  appliedRuleId     BigInt?  @map("applied_rule_id")
  appliedRuleName   String?  @map("applied_rule_name") @db.VarChar(100)
  extractedMetadata Json?    @map("extracted_metadata")
  processingTimeMs  Int?     @map("processing_time_ms")
  success           Boolean  @default(true)
  errorMessage      String?  @map("error_message")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt], map: "idx_regex_logs_created_at")
  @@index([appliedRuleId], map: "idx_regex_logs_rule_id")
  @@map("regex_preprocessing_logs")
}

